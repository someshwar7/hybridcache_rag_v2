# Exclude virtual environments
.venv/
venv/
env/
ENV/

# Exclude sensitive environment secrets
.env
.env.*

# Exclude uploads and temporary preprocessed data
uploads/*
!uploads/.gitkeep
preprocessed_data/

# Exclude application logs
logs/*.log

# Exclude documentation and local diagrams
db workflow.png
doc/
*.md
.gitignore


# Exclude git directories and IDE configurations
.git/
.vscode/
.idea/

# Exclude python cache files
__pycache__/
*.py[cod]
*$py.class

# Exclude local tests
tests/
